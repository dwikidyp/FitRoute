<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash">

    <!-- Konten utama tengah -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Icon Logo -->
        <FrameLayout
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:background="@drawable/bg_icon_logo"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_logo"/>

        </FrameLayout>

        <!-- Nama App -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FitRoute"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lacak rute · elevasi · kalori"
            android:textColor="@color/white_60"
            android:textSize="15sp"
            android:layout_marginBottom="48dp"/>

        <!-- Status loading -->
        <TextView
            android:id="@+id/tvLoadingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Memuat pengaturan sensor..."
            android:textColor="@color/white_60"
            android:textSize="13sp"
            android:layout_marginBottom="16dp"/>

        <!-- Dot indicator -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <View
                android:id="@+id/dot1"
                android:layout_width="24dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_dot_active"
                android:layout_marginEnd="6dp"/>

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_dot_inactive"
                android:layout_marginEnd="6dp"/>

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_dot_inactive"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Bagian bawah: icon fitur + versi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="32dp">

        <!-- Icon fitur -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <!-- Icon GPS -->
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_mylocation"
                android:tint="#99FFFFFF"
                android:layout_marginEnd="24dp"/>

            <!-- Icon Chart/Grafik -->
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="#FFFFFF"
                android:layout_marginEnd="24dp"/>

            <!-- Icon Kompas/Kalori -->
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_compass"
                android:tint="#99FFFFFF"/>

        </LinearLayout>

        <!-- Versi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0.0 · Penelitian UTS"
            android:textColor="@color/white_30"
            android:textSize="11sp"/>

    </LinearLayout>

</FrameLayout>