<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/tvSegmentLabel"
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:text="km 1"
        android:textColor="#1B4332"
        android:textSize="13sp"/>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="@drawable/bg_segment_track"/>

        <View
            android:id="@+id/viewSegmentBar"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_segment_bar"/>

    </FrameLayout>

    <TextView
        android:id="@+id/tvSegmentValue"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:text="+22m"
        android:textColor="#2D6A4F"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="end"/>

</LinearLayout>