<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FAF4">

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER HIJAU ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashboard_header"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingBottom="32dp">

                <!-- Baris atas: sapaan + icon -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <!-- Sapaan -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selamat pagi,"
                            android:textColor="#99FFFFFF"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/tvUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dwiki Dzaki"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:lineSpacingMultiplier="1.1"/>

                    </LinearLayout>

                    <!-- Icon Notif -->
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_popup_reminder"
                        android:tint="#FFFFFF"
                        android:layout_marginEnd="12dp"/>

                    <!-- Icon Profil -->
                    <ImageView
                        android:id="@+id/ivProfile"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        android:tint="#FFFFFF"/>

                </LinearLayout>

                <!-- Card Target Mingguan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_green_dark"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Target mingguan"
                                android:textColor="#99FFFFFF"
                                android:textSize="12sp"
                                android:layout_marginBottom="2dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="34 km dari 50 km (68%)"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="68%"
                            android:textColor="#52B788"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" tercapai"
                            android:textColor="#99FFFFFF"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <!-- Progress Bar -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="8dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_progress_track"/>

                        <View
                            android:id="@+id/viewProgressFill"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_progress_fill"/>

                    </FrameLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ===== STATISTIK 3 KOLOM ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginTop="-1dp">

                <!-- Km minggu ini -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_white"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/tvWeeklyKm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="34.2"
                        android:textColor="#1B4332"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="km minggu ini"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:gravity="center"/>

                </LinearLayout>

                <!-- Kalori terbakar -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_white"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/tvCalories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3.210"
                        android:textColor="#1B4332"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="kalori terbakar"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:gravity="center"/>

                </LinearLayout>

                <!-- Sesi latihan -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_white"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvSessions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textColor="#1B4332"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="sesi latihan"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:gravity="center"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ===== GRAFIK AKTIVITAS MINGGUAN ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp">

                <!-- Judul + link -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Aktivitas minggu ini"
                        android:textColor="#1B4332"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvLihatSemua"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lihat semua"
                        android:textColor="#2D6A4F"
                        android:textSize="13sp"/>

                </LinearLayout>

                <!-- Bar Chart Manual -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_white"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:padding="16dp"
                    android:paddingBottom="8dp">

                    <!-- Sen -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <View android:layout_width="20dp" android:layout_height="40dp"
                            android:background="@drawable/bg_bar_chart"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Sen" android:textSize="10sp" android:textColor="#888888"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Sel -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <View android:layout_width="20dp" android:layout_height="60dp"
                            android:background="@drawable/bg_bar_chart"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Sel" android:textSize="10sp" android:textColor="#888888"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Rab -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <View android:layout_width="20dp" android:layout_height="80dp"
                            android:background="@drawable/bg_bar_chart_active"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Rab" android:textSize="10sp" android:textColor="#2D6A4F"
                            android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Kam -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <View android:layout_width="20dp" android:layout_height="50dp"
                            android:background="@drawable/bg_bar_chart"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Kam" android:textSize="10sp" android:textColor="#888888"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Jum -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <View android:layout_width="20dp" android:layout_height="70dp"
                            android:background="@drawable/bg_bar_chart"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Jum" android:textSize="10sp" android:textColor="#888888"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Sab -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <View android:layout_width="20dp" android:layout_height="55dp"
                            android:background="@drawable/bg_bar_chart"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Sab" android:textSize="10sp" android:textColor="#888888"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Min -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <View android:layout_width="20dp" android:layout_height="30dp"
                            android:background="@drawable/bg_bar_chart"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Min" android:textSize="10sp" android:textColor="#888888"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ===== TOMBOL MULAI SESI ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/btnStartSession"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:background="@drawable/bg_card_green_dark"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <!-- Tombol play bulat -->
                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_start_button"
                        android:layout_marginEnd="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="▶"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"/>

                    </FrameLayout>

                    <!-- Teks -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mulai sesi latihan"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GPS · Elevasi · Kalori aktif"
                            android:textColor="#99FFFFFF"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textColor="#52B788"
                        android:textSize="22sp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ===== AKTIVITAS TERAKHIR ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp">

                <!-- Card Lari -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_recent_card"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏃"
                        android:textSize="22sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lari"
                        android:textColor="#1B4332"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kemarin"
                        android:textColor="#888888"
                        android:textSize="11sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6.4km"
                        android:textColor="#2D6A4F"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <!-- Card Hiking -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_recent_card"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥾"
                        android:textSize="22sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hiking"
                        android:textColor="#1B4332"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sabtu"
                        android:textColor="#888888"
                        android:textSize="11sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12.1km"
                        android:textColor="#2D6A4F"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ===== BOTTOM NAVIGATION ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="8dp">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_compass"
                android:tint="#2D6A4F"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="#2D6A4F"
                android:textSize="10sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Rute -->
        <LinearLayout
            android:id="@+id/navRoute"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_mapmode"
                android:tint="#AAAAAA"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rute"
                android:textColor="#AAAAAA"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- Riwayat -->
        <LinearLayout
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_recent_history"
                android:tint="#AAAAAA"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Riwayat"
                android:textColor="#AAAAAA"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- Profil -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:tint="#AAAAAA"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profil"
                android:textColor="#AAAAAA"
                android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>