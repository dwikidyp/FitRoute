<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_history_card"
    android:orientation="horizontal"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:elevation="2dp">

    <!-- Icon aktivitas -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_activity_icon"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/tvEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🏃"
            android:textSize="18sp"/>

    </FrameLayout>

    <!-- Konten tengah -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Nama aktivitas -->
        <TextView
            android:id="@+id/tvActivityName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lari pagi"
            android:textColor="#1B4332"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <!-- Tanggal + durasi -->
        <TextView
            android:id="@+id/tvDateDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sabtu · 48 mnt"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <!-- Kalori tag -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_calorie_tag"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">

            <TextView
                android:id="@+id/tvCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="418 kcal"
                android:textColor="#2D6A4F"
                android:textSize="11sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Stats kanan -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <!-- Jarak atau elevasi -->
        <TextView
            android:id="@+id/tvMainStat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7.8"
            android:textColor="#1B4332"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="end"/>

        <!-- Pace atau label stat -->
        <TextView
            android:id="@+id/tvMainStatLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="km"
            android:textColor="#888888"
            android:textSize="11sp"
            android:gravity="end"/>

        <!-- Stat kedua -->
        <TextView
            android:id="@+id/tvSecondStat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6:12"
            android:textColor="#2D6A4F"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvSecondStatLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="min/km"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:gravity="end"/>

    </LinearLayout>

</LinearLayout>