<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FAF4">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="90dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashboard_header"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingBottom="28dp">

                <!-- Back + Judul -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/btnBack"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="←"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:layout_marginEnd="10dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Detail sesi"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvHeaderSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hiking Gunung Gede · 24 Mei"
                            android:textColor="#99FFFFFF"
                            android:textSize="12sp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Tag aktivitas -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_activity_tag_small"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tvActivityEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥾 "
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tvActivityTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hiking"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Mini stats di header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Durasi -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvHeaderDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4j 20m"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="durasi"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <!-- Jarak -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvHeaderDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12.1"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="km"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ===== PREVIEW PETA ===== -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="-16dp"
                android:background="@drawable/bg_map_preview"
                android:elevation="4dp"
                android:clipChildren="true">

                <!-- Placeholder peta (ganti dengan SupportMapFragment jika mau) -->
                <fragment
                    android:id="@+id/mapPreview"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

                <!-- Overlay rute dummy (tampil di atas peta) -->
                <com.fitroute.ui.tracking.ElevationChartView
                    android:id="@+id/routeOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"/>

            </FrameLayout>

            <!-- ===== STATS UTAMA 3 KOLOM ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_margin="16dp"
                android:elevation="2dp">

                <!-- Jarak -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12.1"
                        android:textColor="#1B4332"
                        android:textSize="26sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="km jarak"
                        android:textColor="#888888"
                        android:textSize="11sp"/>

                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="48dp"
                    android:background="#EEEEEE"/>

                <!-- Kalori -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCalories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.840"
                        android:textColor="#1B4332"
                        android:textSize="26sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="kcal"
                        android:textColor="#888888"
                        android:textSize="11sp"/>

                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="48dp"
                    android:background="#EEEEEE"/>

                <!-- Elevasi -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvElevGain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+820m"
                        android:textColor="#2D6A4F"
                        android:textSize="26sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="gain"
                        android:textColor="#888888"
                        android:textSize="11sp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ===== PROFIL ELEVASI ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profil elevasi · barometer"
                    android:textColor="#1B4332"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <com.fitroute.ui.tracking.ElevationChartView
                    android:id="@+id/elevationChart"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"/>

            </LinearLayout>

            <!-- ===== ANALISIS SENSOR ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analisis sensor"
                    android:textColor="#1B4332"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <!-- 2 kartu sensor berdampingan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- GPS -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_sensor_card"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📡"
                            android:textSize="20sp"
                            android:layout_marginEnd="8dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GPS"
                                android:textColor="#1B4332"
                                android:textSize="12sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Akurasi tinggi"
                                android:textColor="#52B788"
                                android:textSize="11sp"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Barometer -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_sensor_card"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌡"
                            android:textSize="20sp"
                            android:layout_marginEnd="8dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Barometer"
                                android:textColor="#1B4332"
                                android:textSize="12sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Stabil"
                                android:textColor="#52B788"
                                android:textSize="11sp"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ===== TOMBOL BAWAH: HAPUS & BAGIKAN ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#F0FAF4"
        android:orientation="horizontal"
        android:padding="16dp"
        android:paddingBottom="20dp"
        android:elevation="8dp">

        <!-- Tombol Hapus -->
        <LinearLayout
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:background="@drawable/bg_delete_button"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginEnd="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗑  "
                android:textSize="16sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hapus"
                android:textColor="#FF6B6B"
                android:textSize="15sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Tombol Bagikan -->
        <LinearLayout
            android:id="@+id/btnShare"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:background="@drawable/bg_save_button"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginStart="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⤴  "
                android:textSize="16sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bagikan"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ===== BOTTOM NAVIGATION ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="8dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_compass" android:tint="#AAAAAA"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_mapmode" android:tint="#AAAAAA"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Rute" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_recent_history" android:tint="#2D6A4F"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Riwayat" android:textColor="#2D6A4F" android:textSize="10sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_my_calendar" android:tint="#AAAAAA"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profil" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>