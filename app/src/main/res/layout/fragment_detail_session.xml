<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FAF4">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="90dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashboard_header"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingBottom="32dp">

                <!-- Back + Hapus -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/btnBack"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="←"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Detail sesi"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <!-- Tombol Hapus -->
                    <TextView
                        android:id="@+id/btnDelete"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_sensor_badge"
                        android:text="🗑 Hapus"
                        android:textColor="#FF6B6B"
                        android:textSize="13sp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"/>

                </LinearLayout>

                <!-- Info aktivitas -->
                <TextView
                    android:id="@+id/tvActivityType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏃 Lari pagi"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvDateTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sabtu, 31 Mei 2025 · 07:30"
                    android:textColor="#99FFFFFF"
                    android:textSize="13sp"/>

            </LinearLayout>

            <!-- ===== STATS UTAMA ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="-20dp"
                android:elevation="4dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvDistance" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="7.8"
                        android:textColor="#1B4332" android:textSize="26sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="km" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="48dp"
                    android:background="#EEEEEE"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvDuration" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="48:22"
                        android:textColor="#1B4332" android:textSize="26sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="durasi" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="48dp"
                    android:background="#EEEEEE"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvCalories" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="418"
                        android:textColor="#1B4332" android:textSize="26sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="kcal" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ===== STATS TAMBAHAN ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_margin="16dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvPace" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="6:12"
                        android:textColor="#1B4332" android:textSize="22sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="min/km" android:textColor="#888888" android:textSize="11sp"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="40dp"
                    android:background="#EEEEEE"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvElevGain" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="+186m"
                        android:textColor="#2D6A4F" android:textSize="22sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="elevasi naik" android:textColor="#888888" android:textSize="11sp"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="40dp"
                    android:background="#EEEEEE"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvSpeed" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="9.7"
                        android:textColor="#1B4332" android:textSize="22sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="km/h avg" android:textColor="#888888" android:textSize="11sp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ===== GRAFIK ELEVASI ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profil elevasi"
                    android:textColor="#1B4332"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <com.fitroute.ui.tracking.ElevationChartView
                    android:id="@+id/elevationChart"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ===== TOMBOL BAWAH ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#F0FAF4"
        android:orientation="horizontal"
        android:padding="16dp"
        android:paddingBottom="20dp"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/btnShare"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:background="@drawable/bg_share_button"
            android:gravity="center"
            android:layout_marginEnd="10dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⤴  Bagikan" android:textColor="#2D6A4F"
                android:textSize="15sp" android:textStyle="bold"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:background="@drawable/bg_save_button"
            android:gravity="center"
            android:layout_marginStart="10dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💾  Simpan foto" android:textColor="#FFFFFF"
                android:textSize="15sp" android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>