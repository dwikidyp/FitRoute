<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FAF4">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER HIJAU ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_profile_header"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingBottom="32dp">

                <!-- Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profil saya"
                    android:textColor="#99FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp"/>

                <!-- Baris: info + avatar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <!-- Info kiri -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dwiki Dzaki"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:lineSpacingMultiplier="1.1"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:id="@+id/tvEmail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="dwiki@gmail.com"
                                android:textColor="#99FFFFFF"
                                android:textSize="12sp"
                                android:layout_marginEnd="8dp"/>

                            <!-- Tombol Edit -->
                            <LinearLayout
                                android:id="@+id/btnEdit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_edit_button"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="✏ "
                                    android:textSize="10sp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Edit"
                                    android:textColor="#FFFFFF"
                                    android:textSize="11sp"
                                    android:textStyle="bold"/>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Avatar -->
                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_avatar">

                        <TextView
                            android:id="@+id/tvAvatar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="DD"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold"/>

                    </FrameLayout>

                </LinearLayout>

                <!-- Stats 3 kolom -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Sesi total -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvTotalSessions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="sesi total"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="36dp"
                        android:background="#3DFFFFFF"/>

                    <!-- Total jarak -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvTotalDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="284km"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="total jarak"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="36dp"
                        android:background="#3DFFFFFF"/>

                    <!-- Berat badan -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvWeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="68kg"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="berat badan"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ===== KARTU INFO PRIBADI ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_card"
                android:orientation="vertical"
                android:layout_margin="16dp"
                android:layout_marginTop="-12dp"
                android:padding="16dp"
                android:elevation="4dp">

                <!-- Judul -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INFO PRIBADI"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"/>

                <!-- Usia -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="16sp"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Usia"
                        android:textColor="#888888"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvAge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="22 tahun"
                        android:textColor="#1B4332"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@drawable/bg_divider"/>

                <!-- Jenis Kelamin -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤"
                        android:textSize="16sp"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Jenis kelamin"
                        android:textColor="#888888"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvGender"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Laki-laki"
                        android:textColor="#1B4332"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@drawable/bg_divider"/>

                <!-- Tinggi badan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📏"
                        android:textSize="16sp"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tinggi badan"
                        android:textColor="#888888"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvHeight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="172 cm"
                        android:textColor="#1B4332"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@drawable/bg_divider"/>

                <!-- Berat badan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚖"
                        android:textSize="16sp"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Berat badan"
                        android:textColor="#888888"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvWeightDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="68 kg"
                        android:textColor="#1B4332"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@drawable/bg_divider"/>

                <!-- Aktivitas favorit -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="10dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏃"
                        android:textSize="16sp"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Aktivitas favorit"
                        android:textColor="#888888"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvActivityPref"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lari"
                        android:textColor="#1B4332"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ===== STATS PERFORMA ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_card"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <!-- BMI -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvBmi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="22.9"
                        android:textColor="#1B4332"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvBmiCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="normal"
                        android:textColor="#52B788"
                        android:textSize="11sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BMI"
                        android:textColor="#AAAAAA"
                        android:textSize="10sp"/>

                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="48dp"
                    android:background="#EEEEEE"/>

                <!-- Pace terbaik -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvBestPace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6:12"
                        android:textColor="#1B4332"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="pace avg"
                        android:textColor="#52B788"
                        android:textSize="11sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="min/km"
                        android:textColor="#AAAAAA"
                        android:textSize="10sp"/>

                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="48dp"
                    android:background="#EEEEEE"/>

                <!-- Elevasi terbaik -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvBestElevation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+820m"
                        android:textColor="#1B4332"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="elev terbaik"
                        android:textColor="#52B788"
                        android:textSize="11sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="gain"
                        android:textColor="#AAAAAA"
                        android:textSize="10sp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ===== BADGE ENKRIPSI ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_encrypt_badge"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="20sp"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Data terenkripsi RSA-2048"
                        android:textColor="#1B4332"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tersimpan aman di server"
                        android:textColor="#52B788"
                        android:textSize="11sp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Tombol Tentang Aplikasi -->
            <LinearLayout
                android:id="@+id/btnAbout"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_share_button"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ  Tentang Aplikasi"
                    android:textColor="#2D6A4F"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- ===== TOMBOL LOGOUT ===== -->
            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_delete_button"
                android:gravity="center"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keluar dari akun"
                    android:textColor="#FF6B6B"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ===== BOTTOM NAVIGATION ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="8dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_compass" android:tint="#AAAAAA"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_mapmode" android:tint="#AAAAAA"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Rute" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_recent_history" android:tint="#AAAAAA"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Riwayat" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_my_calendar" android:tint="#2D6A4F"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profil" android:textColor="#2D6A4F" android:textSize="10sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>