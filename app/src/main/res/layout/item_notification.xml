<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notifContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:layout_marginBottom="2dp">

    <!-- Icon tipe notifikasi -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_activity_icon"
        android:layout_marginEnd="14dp">

        <TextView
            android:id="@+id/tvNotifIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🏆"
            android:textSize="20sp"/>

    </FrameLayout>

    <!-- Konten -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNotifTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personal Record Baru!"
            android:textColor="#1B4332"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvNotifBody"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jarak terpanjang: 18.4 km"
            android:textColor="#666666"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvNotifTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 jam lalu"
            android:textColor="#AAAAAA"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- Dot belum dibaca -->
    <View
        android:id="@+id/dotUnread"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_activity_icon_selected"
        android:layout_marginStart="8dp"/>

</LinearLayout>