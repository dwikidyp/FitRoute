<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notifContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Dot belum dibaca -->
    <View
        android:id="@+id/dotUnread"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_dot_unread"
        android:layout_marginEnd="10dp"
        android:visibility="visible"/>

    <!-- Icon bulat -->
    <FrameLayout
        android:id="@+id/iconContainer"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_notif_icon_pr"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/tvNotifIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🏆"
            android:textSize="22sp"/>

    </FrameLayout>

    <!-- Konten teks -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNotifTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personal record baru!"
            android:textColor="#1B4332"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="3dp"/>

        <TextView
            android:id="@+id/tvNotifBody"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jarak terpanjang: 7.8 km lari pagi Sabtu"
            android:textColor="#555555"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="5dp"/>

        <TextView
            android:id="@+id/tvNotifTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 jam lalu"
            android:textColor="#AAAAAA"
            android:textSize="11sp"/>

    </LinearLayout>

</LinearLayout>