<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FAF4">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashboard_header"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="←"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pengaturan"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- ===== SECTION: KEAMANAN ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KEAMANAN"
                android:textColor="#888888"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_card"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="8dp"
                android:elevation="2dp">

                <!-- Login Sidik Jari -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <!-- Icon -->
                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_activity_icon"
                        android:layout_marginEnd="14dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="👆" android:textSize="20sp"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Login sidik jari"
                            android:textColor="#1B4332"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Biometric API aktif"
                            android:textColor="#888888"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchFingerprint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="#2D6A4F"
                        android:trackTint="#B7E4C7"/>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F0F0F0" android:layout_marginStart="74dp"/>

                <!-- Kunci Otomatis -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_activity_icon"
                        android:layout_marginEnd="14dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🔐" android:textSize="20sp"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kunci otomatis"
                            android:textColor="#1B4332"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Setelah 30 detik"
                            android:textColor="#888888"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchAutoLock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:thumbTint="#2D6A4F"
                        android:trackTint="#B7E4C7"/>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F0F0F0" android:layout_marginStart="74dp"/>

                <!-- Enkripsi RSA-2048 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_activity_icon"
                        android:layout_marginEnd="14dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🔒" android:textSize="20sp"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enkripsi RSA-2048"
                            android:textColor="#1B4332"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Transmisi data aman"
                            android:textColor="#888888"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <!-- Badge aktif -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pr_badge"
                        android:text="Aktif"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ===== SECTION: SENSOR & AKURASI ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SENSOR &amp; AKURASI"
                android:textColor="#888888"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingStart="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_card"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="8dp"
                android:elevation="2dp">

                <!-- GPS Akurasi Tinggi -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_activity_icon"
                        android:layout_marginEnd="14dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="📡" android:textSize="20sp"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GPS akurasi tinggi"
                            android:textColor="#1B4332"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Konsumsi baterai +"
                            android:textColor="#888888"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchGpsHigh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="#2D6A4F"
                        android:trackTint="#B7E4C7"/>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F0F0F0" android:layout_marginStart="74dp"/>

                <!-- Sensor Barometer -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_activity_icon"
                        android:layout_marginEnd="14dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🌡" android:textSize="20sp"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sensor barometer"
                            android:textColor="#1B4332"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tracking elevasi aktif"
                            android:textColor="#888888"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchBarometer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="#2D6A4F"
                        android:trackTint="#B7E4C7"/>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F0F0F0" android:layout_marginStart="74dp"/>

                <!-- Deteksi Aktivitas AI -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_activity_icon"
                        android:layout_marginEnd="14dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🤖" android:textSize="20sp"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Deteksi aktivitas AI"
                            android:textColor="#1B4332"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Accelerometer + ML"
                            android:textColor="#888888"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchAutoDetect"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="#2D6A4F"
                        android:trackTint="#B7E4C7"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ===== SECTION: PENYIMPANAN ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENYIMPANAN"
                android:textColor="#888888"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingStart="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_card"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                android:elevation="2dp">

                <!-- Sinkronisasi Cloud -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_activity_icon"
                        android:layout_marginEnd="14dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="☁" android:textSize="20sp"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sinkronisasi cloud"
                            android:textColor="#1B4332"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Saat Wi-Fi tersedia"
                            android:textColor="#888888"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchCloudSync"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="#2D6A4F"
                        android:trackTint="#B7E4C7"/>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F0F0F0" android:layout_marginStart="74dp"/>

                <!-- Mode Offline -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_activity_icon"
                        android:layout_marginEnd="14dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="📱" android:textSize="20sp"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mode offline"
                            android:textColor="#1B4332"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Simpan lokal dulu"
                            android:textColor="#888888"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchOfflineMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:thumbTint="#2D6A4F"
                        android:trackTint="#B7E4C7"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ===== BOTTOM NAVIGATION ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="8dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_compass" android:tint="#AAAAAA"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_mapmode" android:tint="#AAAAAA"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Rute" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_recent_history" android:tint="#AAAAAA"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Riwayat" android:textColor="#AAAAAA" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_my_calendar" android:tint="#2D6A4F"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profil" android:textColor="#2D6A4F" android:textSize="10sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>